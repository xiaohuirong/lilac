# Maintainer: Hoream <hoream@qq.com>
_pkgname="bili-live"
pkgname="${_pkgname}-git"
pkgver=v0.1.8.r3.ge2eff13
pkgrel=1
pkgdesc="A command line tool for starting and stopping live streams on bilibili.com, capable of providing the RTMP address and stream key for streaming software such as OBS."
url="https://github.com/HellOwhatAs/bili-live"
license=("custom")
arch=('x86_64' 'aarch64')
provides=("$_pkgname")
conflicts=("$_pkgname")
depends=()
makedepends=("cargo" "git")
source=("$_pkgname::git+$url")
sha256sums=('SKIP')

prepare() {
	cd "${srcdir}/${_pkgname}"
	export RUSTUP_TOOLCHAIN=stable
	cargo fetch --locked --target "$CARCH-unknown-linux-gnu"
}

pkgver() {
	cd "${srcdir}/${_pkgname}"
	git describe --long --tags | sed 's/\([^-]*-g\)/r\1/;s/-/./g'
}

build() {
	cd "${srcdir}/${_pkgname}"
	export RUSTUP_TOOLCHAIN=stable
	export CARGO_TARGET_DIR=target
	cargo build --frozen --release --all-features
}

check() {
	cd "${srcdir}/${_pkgname}"
	export RUSTUP_TOOLCHAIN=stable
	cargo test --frozen --all-features
}

package() {
	cd "${srcdir}/${_pkgname}"
	install -Dm755 "target/release/${_pkgname}" "${pkgdir}/usr/bin/${_pkgname}"
}
