# Maintainer: Hoream <hoream@qq.com>
pkgname=llm-wiki
_pkgname=llm_wiki
pkgver=0.4.12
pkgrel=1
pkgdesc="A personal knowledge base using an LLM to incrementally build and maintain a persistent wiki"
arch=('x86_64')
url="https://github.com/nashsu/llm_wiki"
license=('GPL-3.0-only')
depends=('gtk3' 'webkit2gtk-4.1' 'libnm' 'libayatana-appindicator')
makedepends=('rust' 'npm' 'nodejs>=20')
source=("$pkgname-$pkgver.tar.gz::$url/archive/refs/tags/v$pkgver.tar.gz"
        "$pkgname.desktop")
sha256sums=('6a5e8f7402bddb57b3cdfbb897405e0dfe963153db873cf2e97233cb8a8b21a2'
            'f23ad78cc2664ee889be0918d33fb44d49009a0f596da80de7408490e507dc39')

prepare() {
  cd "$_pkgname-$pkgver"
  npm install
}

build() {
  cd "$_pkgname-$pkgver"
  npm run tauri build -- --bundles none
}

package() {
  cd "$_pkgname-$pkgver"
  install -Dm755 "src-tauri/target/release/llm-wiki" "$pkgdir/usr/bin/llm-wiki"
  install -Dm644 "src-tauri/icons/128x128.png" "$pkgdir/usr/share/pixmaps/llm-wiki.png"
  install -Dm644 "../$pkgname.desktop" "$pkgdir/usr/share/applications/$pkgname.desktop"
  install -Dm644 "LICENSE" "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
